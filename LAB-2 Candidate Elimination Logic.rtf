\pard\sa200\sl276\slmult1\f0\fs60\lang9 Candidate Elimination Logic\f1\fs22\line\line import pandas as pd\par
\par
# Read dataset\par
data = pd.read_excel("/content/Student_Attendance_Dataset.xlsx")\par
\par
# Use only categorical columns\par
data = data[['Department','Attendance','Assignment','LabCompleted','Eligible']]\par
\par
print(data)\par
\par
concepts = data.iloc[:, :-1].values\par
target = data.iloc[:, -1].values\par
\par
# Initialize Specific Hypothesis\par
specific_h = concepts[0].copy()\par
\par
# Initialize General Hypothesis\par
general_h = [["?" for i in range(len(specific_h))] for i in range(len(specific_h))]\par
\par
for i, h in enumerate(concepts):\par
\par
    if target[i] == "Yes":\par
\par
        for x in range(len(specific_h)):\par
            if h[x] != specific_h[x]:\par
                specific_h[x] = "?"\par
                general_h[x][x] = "?"\par
\par
    elif target[i] == "No":\par
\par
        for x in range(len(specific_h)):\par
            if h[x] != specific_h[x]:\par
                general_h[x][x] = specific_h[x]\par
            else:\par
                general_h[x][x] = "?"\par
\par
# Remove redundant hypotheses\par
general_h = [g for g in general_h if g != ["?"] * len(specific_h)]\par
\par
print("\\nSpecific Hypothesis:")\par
print(specific_h)\par
\par
print("\\nGeneral Hypothesis:")\par
for g in general_h:\par
    print(g)\par
output\par

