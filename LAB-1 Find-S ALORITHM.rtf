\pard\sa200\sl276\slmult1\par
\par
import pandas as pd\par
\par
# Read the dataset\par
data = pd.read_excel("/content/Student_Attendance_Dataset.xlsx")\par
\par
# Use only categorical columns\par
data = data[['Department','Attendance','Assignment','LabCompleted','Eligible']]\par
print(data)\par
X = data.iloc[:, :-1].values\par
Y = data.iloc[:, -1].values\par
\par
# Find first positive example\par
for i in range(len(Y)):\par
    if Y[i] == "Yes":\par
        S = X[i].copy()\par
        break\par
# Find-S\par
for i in range(len(Y)):\par
    if Y[i] == "Yes":\par
        for j in range(len(S)):\par
            if S[j] != X[i][j]:\par
                S[j] = "?"\par
\par
print("\\nFinal Hypothesis:")\par
print(S)\par
